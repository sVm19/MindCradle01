# MindCradle Backend Environment Variables
# Copy this to .env and fill in your values.
# In production: set ENVIRONMENT=production and use https:// for FRONTEND_URL.

# Runtime environment: "development" (default) or "production"
ENVIRONMENT=development

# Supabase
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase JWT Secret — used to cryptographically verify user tokens.
# Get it from: Supabase Dashboard → Project Settings → API → JWT Secret
# NEVER commit this value. NEVER log it.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AI API (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Frontend URL (for CORS)
# Development:  FRONTEND_URL=http://localhost:5173
# Production:   FRONTEND_URL=https://mindcradle.online   (MUST be https://)
FRONTEND_URL=http://localhost:5173

# JWT token lifetimes and custom security settings
JWT_SECRET_KEY=your-super-long-random-secret-here
JWT_REFRESH_SECRET_KEY=another-super-long-random-secret-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_TIMEOUT_MINUTES=30

# Password validation and hashing settings
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Creem Settings
CREEM_API_KEY=your-creem-api-key
CREEM_API_URL=https://test-api.creem.io
CREEM_PRODUCT_ID=your-creem-product-id


